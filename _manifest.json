{
  "manifest_version": 2,
  "version": "3.2.0",
  "name": "GPT-SoVITS V2 TTS",
  "description": "基于本地 GPT-SoVITS V2 API 的文本转语音插件，支持 /vits 命令和关键词语音触发。",
  "author": {
    "name": "HatsuYukiAya初雪绫",
    "url": "https://github.com/Shiroha135"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/Shiroha135/GPT-SoVITS-v2-TTS-Plugin",
    "homepage": "https://github.com/Shiroha135/GPT-SoVITS-v2-TTS-Plugin",
    "documentation": "https://github.com/Shiroha135/GPT-SoVITS-v2-TTS-Plugin",
    "issues": "https://github.com/Shiroha135/GPT-SoVITS-v2-TTS-Plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.5.2",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "aiohttp",
      "version_spec": ">=3.12.0"
    },
    {
      "type": "python_package",
      "name": "aiofiles",
      "version_spec": ">=23.0.0"
    }
  ],
  "capabilities": [
    "send.text",
    "send.custom",
    "llm.generate"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": null,
    "supported_locales": [
      "zh-CN"
    ]
  },
  "plugin_type": "extension",
  "display": {
    "icon": {
      "type": "lucide",
      "value": "volume-2",
      "background": "#3B82F6"
    }
  },
  "id": "hatsuyukiaya.gpt-sovits-v2-tts"
}
